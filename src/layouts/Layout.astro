---
import "../styles/global.css";
import { brand, footer, tallyFormId } from "../data/globals";

interface Props {
    title: string;
}

const { title } = Astro.props;
const year = new Date().getFullYear();
const tallyUrl = `#tally-open=${tallyFormId}&tally-emoji-text=👋&tally-emoji-animation=wave`;
---

<!DOCTYPE html>
<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <script async src="https://tally.so/widgets/embed.js"></script>

        <meta name="description" content="marini.jp" />
        <meta name="author" content="marini.jp" />
        <meta name="keywords" content="sci-fi, fantasy, books, writing" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content="marini.jp" />
        <meta property="og:type" content="website" />
        <meta name="theme-color" content="#ffffff" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="robots" content="index, follow" />
        <meta http-equiv="Content-Language" content="ja" />
        <meta name="robots" content="noai" />
        <meta name="robots" content="noimageai" />
        <meta name="ai-policy" content="noai" />
    </head>
    <body class="bg-white height-full">
        <div class="min-h-screen flex flex-col">
            <!-- Navigation -->
            <nav class="bg-white-500">
                <div class="max-w-screen-lg flex flex-wrap items-center justify-between mx-auto p-4">
                    <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
                        <img src={`/${brand.navLogoSmall}`} class="h-8" alt="marini" />
                        <img src={`/${brand.navLogoFull}`} class="h-8" alt="marini" />
                    </a>

                    <ul class="flex flex-col md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0">
                        <li class="text-right text-sm flex flex-row items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 mr-2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 0 1-.923 1.785A5.969 5.969 0 0 0 6 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337Z" />
                            </svg>
                            <a href={tallyUrl} class="hover:text-mblue-400">お問い合わせ</a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Nav/content border -->
            <div class="w-full h-2 bg-mblue-400"></div>

            <!-- Content -->
            <div class="bg-slate-50 flex flex-col items-center justify-top grow">
                <slot />
            </div>

            <!-- Footer -->
            <footer class="w-full bg-mblue-400 text-white py-4 text-center">
                <div class="py-8 px-4">
                    <p class="text-xs mb-3">{footer.copyrightJa}</p>
                    <p class="text-xs mb-3">
                        {footer.copyrightEn}<br />
                        &copy; marini {year} All rights reserved.
                    </p>

                    <ul class="flex flex-col justify-center items-center">
                        <li class="text-right text-sm flex flex-row items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 mr-2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 0 1-.923 1.785A5.969 5.969 0 0 0 6 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337Z" />
                            </svg>
                            <a href={tallyUrl} class="hover:text-morange-400">お問い合わせフォーム</a>
                        </li>
                    </ul>
                </div>
            </footer>
        </div>
    </body>
</html>
