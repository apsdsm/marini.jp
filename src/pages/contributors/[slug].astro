---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const contributors = await getCollection("contributors");
    return contributors.map((c) => ({
        params: { slug: c.id },
        props: { contributor: c },
    }));
}

const { contributor } = Astro.props;
const { Content } = await render(contributor);

// Resolve publications
const pubSlugs = contributor.data.publications ?? [];
const allPubs = pubSlugs.length > 0
    ? (await getCollection("publications")).filter((p) => pubSlugs.includes(p.id))
    : [];
const sortedPubs = pubSlugs
    .map((slug) => allPubs.find((p) => p.id === slug))
    .filter(Boolean);
---

<Layout title={`${contributor.data.name} - marini.jp`}>
    <div class="w-full flex flex-col items-center bg-white max-w-screen-lg shadow-lg">
        <section class="w-full max-w-screen-lg">
            <div class="p-4 w-full">
                <h1 class="w-full text-mblue-400">{contributor.data.name}</h1>
                {contributor.data.nameJa && (
                    <h1 class="w-full border-b-1 pb-2 mb-4 text-mblue-400 text-sm">{contributor.data.nameJa}</h1>
                )}

                <div class="flex flex-col items-top justify-center sm:flex-row">
                    {contributor.data.profilePicture && (
                        <div class="sm:min-w-56 p-4 flex flex-col items-center">
                            <img src={`/${contributor.data.profilePicture}`} alt={contributor.data.name} class="max-w-56 h-auto" />
                        </div>
                    )}

                    <div>
                        <div class="prose prose-sm p-4 max-w-none prose-h2:text-sm prose-p:text-xs">
                            <Content />
                        </div>

                        {sortedPubs.length > 0 && (
                            <div class="sm:min-w-56 p-4 flex flex-col items-center">
                                <div class="w-full">
                                    <h2 class="text-mblue-400 text-xs border-b-1">著書</h2>

                                    <div class="flex flex-wrap justify-left w-full">
                                        {sortedPubs.map((pub) => (
                                            <div class="w-1/2 sm:w-1/3 md:w-1/4 p-3">
                                                <a href={`/publications/${pub!.id}`} class="drop-shadow-md">
                                                    <img src={`/${pub!.data.coverSmall}`} alt={pub!.data.title} class="w-full h-auto block drop-shadow-md" />
                                                </a>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        )}
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>
